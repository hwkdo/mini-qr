# Environment variables for MiniQR

# Crowdin configuration for translations
CROWDIN_PERSONAL_TOKEN="your_personal_token"
CROWDIN_PROJECT_ID="your_project_id"

# Base path for deployment (e.g., /mini-qr for deploying at domain.com/mini-qr)
# Default: ./ (relative paths, works at any sub-path without configuration)
BASE_PATH=/

VITE_HIDE_CREDITS=false
VITE_DEFAULT_PRESET=HWKDO
VITE_DEFAULT_DATA_TO_ENCODE=
VITE_QR_CODE_PRESETS=[{"name":"HWKDO","type":"svg","backgroundOptions":{"color":"transparent"},"data":"Inhalt des QR-Code hier.","image":"data:image/png;base64,","width":200,"height":200,"margin":0,"dotsOptions":{"color":"#073070","type":"dots"},"cornersSquareOptions":{"color":"#456494","type":"rounded"},"cornersDotOptions":{"color":"#456494","type":"dot"},"imageOptions":{"margin":0},"qrOptions":{"errorCorrectionLevel":"H"},"style":{"borderRadius":"0px","background":"#70abec"},"frame":{"text":"QR-Code Titel","position":"bottom","style":{"textColor":"#073070","backgroundColor":"#79abec","borderColor":"#000000","borderWidth":"2px","borderRadius":"16px","padding":"20px","fontFamily":"Arial, sans-serif"}}}]

VITE_FRAME_PRESET=HWKDO
VITE_FRAME_PRESETS=[{"name":"HWKDO","text":"QR-Code Titel","position":"bottom","style":{"textColor":"#073070","backgroundColor":"#79abec","borderColor":"#000000","borderWidth":"2px","borderRadius":"16px","padding":"20px","fontFamily":"Arial, sans-serif"}}]
VITE_DISABLE_LOCAL_STORAGE=false
VITE_ENABLE_ANALYTICS=false
DEFAULT_PRESET=HWKDO
FRAME_PRESET=HWKDO
HIDE_CREDITS=false
DISABLE_LOCAL_STORAGE=true
